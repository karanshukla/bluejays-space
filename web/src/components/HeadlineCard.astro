---
import type { Headline } from '../lib/db';
import { permalinkPath } from '../lib/slug';
import { getSiteUrl } from '../lib/site';
import { smallVariantKey } from '../lib/photoImport';

// Keyed off the headline id, not list position, so a card's tape stays put as
// other headlines publish/unpublish around it.
export const TAPE_VARIANTS = ['tape-a', 'tape-b', 'tape-c', 'tape-d', 'tape-e', 'tape-f'];

// Subtle per-card photo crop offsets so the scrapbook doesn't look like every
// photo was mounted dead-center. Kept close to center (35-65%) so cover-crop
// never clips a face badly. A prime-multiplied index (vs. TAPE_VARIANTS'
// plain h.id % n) keeps tape rotation and photo offset from lining up in a
// visible pattern across consecutive ids.
export const PHOTO_POSITION_VARIANTS = [
  '50% 35%',
  '35% 50%',
  '65% 40%',
  '40% 65%',
  '60% 45%',
  '45% 60%',
  '55% 30%',
];

interface Props {
  headline: Headline;
  // On a permalink page, the focused card stays full-opacity; every other card
  // is dimmed to draw the eye to the one being shared.
  dimmed?: boolean;
  // First few cards render above the fold on most breakpoints — skip
  // lazy-loading for those so the browser doesn't delay their LCP candidate.
  eager?: boolean;
}

const { headline: h, dimmed = false, eager = false } = Astro.props;
const tapeVariant = TAPE_VARIANTS[h.id % TAPE_VARIANTS.length];
const photoPosition = PHOTO_POSITION_VARIANTS[(h.id * 7) % PHOTO_POSITION_VARIANTS.length];
const url = permalinkPath(h.id, h.headline);
const siteHost = getSiteUrl().hostname;
// Only webp uploads (the resize path in photoImport.ts) have a small variant
// stored alongside — the untouched-GIF path has just the one file.
const hasSmallVariant = h.photo_ref?.endsWith('.webp') ?? false;
---

<li data-headline-id={h.id}>
  <div
    class={`clipping ${tapeVariant} ${dimmed ? 'dimmed' : ''} border border-paper-edge bg-card p-5 pt-7 shadow-[3px_4px_0_rgba(20,33,61,0.12),0_10px_24px_-8px_rgba(20,33,61,0.28)]`}
  >
    {
      h.photo_ref && (
        <div class="photo-mount border border-paper-edge">
          <img
            src={`/api/images/${h.photo_ref}`}
            srcset={
              hasSmallVariant
                ? `/api/images/${smallVariantKey(h.photo_ref)} 640w, /api/images/${h.photo_ref} 1024w`
                : undefined
            }
            sizes={hasSmallVariant ? '(min-width: 640px) 460px, 100vw' : undefined}
            alt={h.headline}
            width="640"
            height="480"
            loading={eager ? 'eager' : 'lazy'}
            decoding="async"
            fetchpriority={eager ? 'high' : 'auto'}
            style={`object-position: ${photoPosition};`}
          />
        </div>
      )
    }

    <h2
      class={`text-xl leading-snug font-semibold text-ink font-display ${h.photo_ref ? 'mt-4' : ''}`}
    >
      {h.headline}
    </h2>

    {
      h.stat_block && (
        <p class="mt-3 border-t border-dashed border-blue/40 pt-3 font-mono text-xs text-ink-soft">
          {h.stat_block}
        </p>
      )
    }

    {
      h.source_note && (
        <p class="mt-2 font-mono text-[0.65rem] text-ink-soft/70 italic">
          Source:{' '}
          {h.source_post_url ? (
            <a href={h.source_post_url} class="not-italic hover:underline">
              {h.source_note}
            </a>
          ) : (
            h.source_note
          )}
        </p>
      )
    }

    <div class="mt-4 flex items-center justify-between border-t border-dashed border-blue/20 pt-1">
      <a
        href={url}
        class="card-action -ml-2 flex items-center gap-1.5 rounded-full p-2 text-ink-soft/50 transition-colors hover:bg-blue/10 hover:text-blue"
        title="Open this headline"
        aria-label="Open this headline"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="3"></circle><circle cx="12" cy="12" r="9"></circle></svg
        >
      </a>

      <span class="flex flex-col items-center gap-0.5">
        <span class="font-mono text-[0.6rem] font-bold tracking-widest text-ink-soft/30 uppercase">
          {siteHost}
        </span>
        {
          h.submitter_name && (
            <span class="font-mono text-[0.6rem] text-ink-soft/50">
              submitted by {h.submitter_name}
            </span>
          )
        }
      </span>

      <button
        type="button"
        class="copy-link card-action -mr-2 flex items-center gap-1.5 rounded-full p-2 text-ink-soft/50 transition-colors hover:bg-blue/10 hover:text-blue"
        data-url={url}
        title="Copy link"
        aria-label="Copy link to this headline"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg
        >
      </button>
    </div>
  </div>
</li>
