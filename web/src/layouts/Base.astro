---
import '../styles/global.css';
// Fraunces: self-hosted display serif for headlines. Imported as JS modules so
// Vite bundles the WOFF2 files into the build (no Google Fonts CDN). Two weights
// only to keep the bundle lean.
import '@fontsource/fraunces/600.css';
import '@fontsource/fraunces/400.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-900 antialiased">
    <header class="flex justify-end px-6 py-4">
      <a
        href="https://handles.bluejays.space"
        class="text-sm font-medium text-blue-700 hover:underline"
      >
        Claim a free @handle.bluejays.space &rarr;
      </a>
    </header>
    <slot />
    <footer class="mt-16 px-6 py-8 text-center text-xs text-neutral-500">
      <p>
        <strong>bluejays.space</strong> is a parody/satire site. Not affiliated with MLB or the Toronto
        Blue Jays.
      </p>
    </footer>
  </body>
</html>
