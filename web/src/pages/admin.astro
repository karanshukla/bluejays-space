---
// /admin — draft review UI. Gated by Cloudflare Access JWT verification in
// middleware (see src/middleware.ts), not just Cloudflare's edge path-scoping —
// the app verifies the JWT so Railway's direct fallback domain can't bypass it.
//
// Each draft renders as a Svelte island (DraftCard) for optimistic inline edit
// + publish. The list shell stays server-rendered Astro; the API routes are
// unchanged (form-POST bodies, called via fetch now).
import Base from '../layouts/Base.astro';
import DraftCard from '../components/DraftCard.svelte';
import { getDraftHeadlines } from '../lib/db';

export const prerender = false;

const drafts = await getDraftHeadlines();
---

<Base title="Admin — bluejays.space">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-semibold font-display">Admin — drafts</h1>
    <p class="mt-2 text-sm text-neutral-600">
      {drafts.length} draft{drafts.length === 1 ? '' : 's'} awaiting review. Only published rows appear
      on the public feed.
    </p>

    {
      drafts.length === 0 && (
        <p class="mt-8 text-neutral-500">
          No drafts right now. Run the ingest job to generate some.
        </p>
      )
    }

    <ul class="mt-8 space-y-8">
      {drafts.map((draft) => <DraftCard client:load draft={draft} />)}
    </ul>
  </main>
</Base>
