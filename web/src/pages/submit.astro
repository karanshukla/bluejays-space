---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import PhotoInput from '../components/PhotoInput.svelte';
import {
  HEADLINE_MAX,
  SUBMITTER_NAME_MAX,
  STAT_BLOCK_MAX,
  SOURCE_NOTE_MAX,
} from '../lib/submissionLimits';

export const prerender = false;

const sent = Astro.url.searchParams.has('sent');
const error = Astro.url.searchParams.get('error');
const errorMessage: Record<string, string> = {
  missing: "Headline can't be empty.",
  too_long: `Keep the headline under ${HEADLINE_MAX} characters (and the other fields short too).`,
  rate_limited: 'Too many submissions from you recently. Try again in a bit.',
};
---

<Base
  title="Submit a headline · bluejays.space"
  description="Send in a Blue Jays headline idea for review."
>
  <main class="mx-auto max-w-xl px-6 py-16">
    <SiteHeader />
    <h2 class="mt-6 text-center text-3xl font-semibold tracking-tight text-ink font-display">
      Submit a headline
    </h2>
    <p class="mt-4 text-center text-sm text-ink-soft">
      Got a bit? Feeling a little down on the Jays? Submit something you think is funny. All
      submissions are human reviewed, and may take some time to appear.
    </p>

    {
      sent && (
        <p class="mt-8 rounded-lg border border-paper-edge bg-card p-4 text-center text-sm font-medium text-ink">
          Thanks for submitting and contributing! It's in the queue for review.
        </p>
      )
    }

    {
      error && errorMessage[error] && (
        <p class="mt-8 rounded-lg border border-red/30 bg-red/5 p-4 text-center text-sm font-medium text-red">
          {errorMessage[error]}
        </p>
      )
    }

    <form
      class="mt-8 space-y-4 rounded-lg border border-paper-edge bg-card p-6"
      method="POST"
      action="/api/submit"
    >
      <label class="block text-sm font-medium text-ink">
        Headline
        <textarea
          name="headline"
          required
          rows="3"
          maxlength={HEADLINE_MAX}
          placeholder={`e.g. "Bo Bichette's bat found unresponsive at scene"`}
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-base text-ink font-display"
        ></textarea>
      </label>

      <label class="block text-sm font-medium text-ink">
        Stat block/Subtitle <span class="font-normal text-ink-soft/70">(optional)</span>
        <input
          name="stat_block"
          maxlength={STAT_BLOCK_MAX}
          placeholder="e.g. .320 AVG, 40 HR"
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-ink font-mono text-sm"
        />
      </label>

      <label class="block text-sm font-medium text-ink">
        What's this riffing on? <span class="font-normal text-ink-soft/70">(optional)</span>
        <input
          name="source_note"
          maxlength={SOURCE_NOTE_MAX}
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-ink"
        />
      </label>

      <div>
        <span class="block text-sm font-medium text-ink">
          Photo <span class="font-normal text-ink-soft/70">(optional)</span>
        </span>
        <div class="mt-1">
          <PhotoInput
            client:load
            name="photo_ref"
            importEndpoint="/api/submit-photo"
            allowRawKey={false}
          />
        </div>
      </div>

      <label class="block text-sm font-medium text-ink">
        Your name <span class="font-normal text-ink-soft/70">(optional, shown on the card)</span>
        <input
          name="submitter_name"
          maxlength={SUBMITTER_NAME_MAX}
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-ink"
        />
      </label>

      <button
        type="submit"
        class="w-full rounded bg-blue px-4 py-2 text-sm font-semibold text-white hover:opacity-90"
      >
        Send it in
      </button>
    </form>
  </main>
</Base>
