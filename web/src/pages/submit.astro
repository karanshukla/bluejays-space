---
import Base from '../layouts/Base.astro';
import { HEADLINE_MAX, SUBMITTER_NAME_MAX, CONTEXT_NOTE_MAX } from '../lib/submissionLimits';

export const prerender = false;

const sent = Astro.url.searchParams.has('sent');
const error = Astro.url.searchParams.get('error');
const errorMessage: Record<string, string> = {
  missing: "Headline can't be empty.",
  too_long: `Keep it under ${HEADLINE_MAX} characters (and your name/context short too).`,
  rate_limited: 'Too many submissions from you recently — try again in a bit.',
};
---

<Base
  title="Submit a headline · bluejays.space"
  description="Send in a Blue Jays headline idea for review."
>
  <main class="mx-auto max-w-xl px-6 py-16">
    <h1 class="text-center text-4xl font-semibold tracking-tight text-ink font-display">
      Submit a headline
    </h1>
    <p class="mt-4 text-center text-sm text-ink-soft">
      Got a bit? Send it in. Every submission goes into the same review queue as everything else on
      the site — nothing publishes until a human's read it.
    </p>

    {
      sent && (
        <p class="mt-8 rounded-lg border border-paper-edge bg-card p-4 text-center text-sm font-medium text-ink">
          Thanks — it's in the queue for review.
        </p>
      )
    }

    {
      error && errorMessage[error] && (
        <p class="mt-8 rounded-lg border border-red/30 bg-red/5 p-4 text-center text-sm font-medium text-red">
          {errorMessage[error]}
        </p>
      )
    }

    <form
      class="mt-8 space-y-4 rounded-lg border border-paper-edge bg-card p-6"
      method="POST"
      action="/api/submit"
    >
      <label class="block text-sm font-medium text-ink">
        Headline
        <textarea
          name="headline"
          required
          rows="3"
          maxlength={HEADLINE_MAX}
          placeholder={`e.g. "Bo Bichette's bat found unresponsive at scene"`}
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-base text-ink font-display"
        ></textarea>
      </label>

      <label class="block text-sm font-medium text-ink">
        Your name <span class="font-normal text-ink-soft/70">(optional — shown on the card)</span>
        <input
          name="submitter_name"
          maxlength={SUBMITTER_NAME_MAX}
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-ink"
        />
      </label>

      <label class="block text-sm font-medium text-ink">
        What's this riffing on? <span class="font-normal text-ink-soft/70">(optional)</span>
        <input
          name="context_note"
          maxlength={CONTEXT_NOTE_MAX}
          class="mt-1 w-full rounded border border-paper-edge bg-paper p-2 text-ink"
        />
      </label>

      <button
        type="submit"
        class="w-full rounded bg-blue px-4 py-2 text-sm font-semibold text-white hover:opacity-90"
      >
        Send it in
      </button>
    </form>
  </main>
</Base>
