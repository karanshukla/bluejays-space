---
import Base from '../../layouts/Base.astro';
import HeadlineCard from '../../components/HeadlineCard.astro';
import { getHeadlineById, getPublishedHeadlines } from '../../lib/db';
import { permalinkPath } from '../../lib/slug';

export const prerender = false;

// The param is `{id}-{slug}` (e.g. "7-vladimir-guerrero-jr-hits-ball-into-orbit").
// A bare id ("7") still works — redirect to the canonical slugged URL for SEO.
const match = Astro.params.id?.match(/^(\d+)/);
const id = match ? Number(match[1]) : NaN;
if (!Number.isInteger(id) || id <= 0) {
  return new Response('Not Found', { status: 404 });
}

const headline = await getHeadlineById(id);
if (!headline) {
  return new Response('Not Found', { status: 404 });
}

const canonical = permalinkPath(id, headline.headline);
if (Astro.url.pathname !== canonical) {
  return Astro.redirect(canonical, 301);
}

const headlines = await getPublishedHeadlines();

// Point the dynamic OG card only at known link-preview crawlers — a human
// reading the page doesn't need the per-headline image rendered, and skipping
// it avoids the Satori+resvg pass on ordinary browser visits.
const crawlerUA = /Bluesky Cardyb|Discordbot|Twitterbot|Slackbot|facebookexternalhit/i;
const isCrawler = crawlerUA.test(Astro.request.headers.get('user-agent') ?? '');
const ogImage = isCrawler ? `/api/og/${id}.png` : undefined;
---

<Base
  title={headline.headline}
  description={headline.stat_block ?? undefined}
  ogType="article"
  canonicalPath={canonical}
  ogImage={ogImage}
>
  <main class="permalink-overlay mx-auto max-w-[1600px] px-6 py-12 sm:px-10" data-focus-id={id}>
    <a href="/" class="block text-center transition-opacity hover:opacity-80">
      <h1 class="text-5xl font-semibold tracking-tight text-ink font-display sm:text-6xl">
        bluejays.space
      </h1>
    </a>

    <ul class="scrapbook-grid mt-14">
      {headlines.map((h) => <HeadlineCard headline={h} dimmed={h.id !== id} />)}
    </ul>
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-link').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const path = btn.dataset.url;
        if (!path) return;
        try {
          await navigator.clipboard.writeText(`${location.origin}${path}`);
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.style.color = 'var(--color-blue)';
            setTimeout(() => (svg.style.color = ''), 1500);
          }
        } catch {
          window.open(path, '_blank');
        }
      });
    });

    // Scroll the focused card into view on load — especially important on
    // mobile where the card could be anywhere in the feed.
    const focusId = document.querySelector<HTMLElement>('.permalink-overlay')?.dataset.focusId;
    if (focusId) {
      document
        .querySelector<HTMLLIElement>(`li[data-headline-id="${focusId}"]`)
        ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // Click anywhere that isn't the focused card → back to the feed. Checking
    // against `.clipping` in general was a bug: every dimmed background card
    // matches that selector too, so on a feed with more than a couple of
    // headlines the greyed-out backdrop (the part users actually click,
    // expecting a lightbox-style dismiss) covered almost the entire page and
    // silently did nothing. Only the one focused card should count as "safe";
    // every other card is backdrop. Links/buttons always keep their own
    // behavior (open the other headline, copy its link) regardless of which
    // card they're in.
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a, button')) return;

      const focusedCard = focusId
        ? document.querySelector(`li[data-headline-id="${focusId}"] .clipping`)
        : null;
      if (focusedCard?.contains(target)) return;

      window.location.href = '/';
    });
  </script>
</Base>
