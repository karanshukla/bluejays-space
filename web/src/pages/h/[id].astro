---
import Base from '../../layouts/Base.astro';
import HeadlineCard from '../../components/HeadlineCard.astro';
import { getHeadlineById, getPublishedHeadlines } from '../../lib/db';
import { permalinkPath } from '../../lib/slug';

export const prerender = false;

// The param is `{id}-{slug}` (e.g. "7-vladimir-guerrero-jr-hits-ball-into-orbit").
// A bare id ("7") still works — redirect to the canonical slugged URL for SEO.
const match = Astro.params.id?.match(/^(\d+)/);
const id = match ? Number(match[1]) : NaN;
if (!Number.isInteger(id) || id <= 0) {
  return new Response('Not Found', { status: 404 });
}

const headline = await getHeadlineById(id);
if (!headline) {
  return new Response('Not Found', { status: 404 });
}

const canonical = permalinkPath(id, headline.headline);
if (Astro.url.pathname !== canonical) {
  return Astro.redirect(canonical, 301);
}

const headlines = await getPublishedHeadlines();

// Point the dynamic OG card only at known link-preview crawlers — a human
// reading the page doesn't need the per-headline image rendered, and skipping
// it avoids the Satori+resvg pass on ordinary browser visits.
const crawlerUA = /Bluesky Cardyb|Discordbot|Twitterbot|Slackbot|facebookexternalhit/i;
const isCrawler = crawlerUA.test(Astro.request.headers.get('user-agent') ?? '');
const ogImage = isCrawler ? `/api/og/${id}.png` : undefined;
---

<Base
  title={headline.headline}
  description={headline.stat_block ?? undefined}
  ogType="article"
  canonicalPath={canonical}
  ogImage={ogImage}
>
  <main class="permalink-overlay mx-auto max-w-[1600px] px-6 py-12 sm:px-10" data-home="/">
    <a
      href="/"
      class="font-mono text-xs font-bold tracking-wide text-blue uppercase hover:underline"
    >
      &larr; Back to the feed
    </a>

    <ul class="scrapbook-grid mt-8">
      {headlines.map((h) => <HeadlineCard headline={h} dimmed={h.id !== id} />)}
    </ul>
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-link').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const path = btn.dataset.url;
        if (!path) return;
        try {
          await navigator.clipboard.writeText(`${location.origin}${path}`);
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.style.color = 'var(--color-blue)';
            setTimeout(() => (svg.style.color = ''), 1500);
          }
        } catch {
          window.open(path, '_blank');
        }
      });
    });

    // Click on the empty space around the cards (not on a card itself) → home.
    const overlay = document.querySelector('.permalink-overlay');
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) window.location.href = '/';
    });
  </script>
</Base>
