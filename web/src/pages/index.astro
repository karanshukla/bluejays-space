---
import Base from '../layouts/Base.astro';
import HeadlineCard from '../components/HeadlineCard.astro';
import { getPublishedHeadlines } from '../lib/db';

export const prerender = false;

const headlines = await getPublishedHeadlines();
---

<Base title="bluejays.space">
  <main class="mx-auto max-w-[1600px] px-6 py-12 sm:px-10">
    <h1 class="text-center text-5xl font-semibold tracking-tight text-ink font-display sm:text-6xl">
      bluejays.space
    </h1>

    {
      headlines.length === 0 && (
        <p class="mt-16 text-center font-mono text-sm text-ink-soft">
          No headlines published yet. Check back soon.
        </p>
      )
    }

    <ul class="scrapbook-grid mt-14">
      {headlines.map((h) => <HeadlineCard headline={h} />)}
    </ul>
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-link').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const path = btn.dataset.url;
        if (!path) return;
        try {
          await navigator.clipboard.writeText(`${location.origin}${path}`);
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.style.color = 'var(--color-blue)';
            setTimeout(() => (svg.style.color = ''), 1500);
          }
        } catch {
          window.open(path, '_blank');
        }
      });
    });

    // Remember the feed's scroll position so tapping outside the focused card
    // on a permalink page (see h/[id].astro) can restore it here, instead of
    // that fresh navigation always landing at the top of the page.
    window.addEventListener(
      'scroll',
      () => sessionStorage.setItem('feedScrollY', String(window.scrollY)),
      { passive: true }
    );

    const params = new URLSearchParams(location.search);
    if (params.has('restoreScroll')) {
      const y = Number(sessionStorage.getItem('feedScrollY'));
      if (Number.isFinite(y) && y > 0) window.scrollTo(0, y);
      params.delete('restoreScroll');
      const rest = params.toString();
      history.replaceState(null, '', location.pathname + (rest ? `?${rest}` : ''));
    }
  </script>
</Base>
