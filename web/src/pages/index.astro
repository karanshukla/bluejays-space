---
import Base from '../layouts/Base.astro';
import { getPublishedHeadlines } from '../lib/db';

export const prerender = false;

const headlines = await getPublishedHeadlines();

// Deterministic per-card tape variant (angle/length/placement/color), keyed
// off the headline's own id rather than its position in the list — a card's
// tape stays put as other headlines publish/unpublish around it, the way a
// real scrapbook page wouldn't re-tape itself every time you turned back to
// it. See the .tape-a..f rules in global.css.
const TAPE_VARIANTS = ['tape-a', 'tape-b', 'tape-c', 'tape-d', 'tape-e', 'tape-f'];
---

<Base title="bluejays.space">
  <main class="mx-auto max-w-6xl px-6 py-12 sm:px-10">
    <h1 class="text-center text-5xl font-semibold tracking-tight text-ink font-display sm:text-6xl">
      bluejays.space
    </h1>

    {
      headlines.length === 0 && (
        <p class="mt-16 text-center font-mono text-sm text-ink-soft">
          No headlines published yet. Check back soon.
        </p>
      )
    }

    <ul class="scrapbook-grid mt-14">
      {
        headlines.map((h) => {
          // Real alt text for the public feed: a player name when player_ids is
          // populated, otherwise decorative (empty) per docs/ui-plan.md.
          const photoAlt = h.player_ids?.[0] ? `${h.player_ids[0]}` : '';
          const tapeVariant = TAPE_VARIANTS[h.id % TAPE_VARIANTS.length];
          return (
            <li>
              <div
                class={`clipping ${tapeVariant} relative border border-paper-edge bg-card p-5 pt-7 shadow-[3px_4px_0_rgba(20,33,61,0.12),0_10px_24px_-8px_rgba(20,33,61,0.28)]`}
              >
                {h.photo_ref && (
                  <div class="photo-mount border border-paper-edge">
                    <img src={`/api/images/${h.photo_ref}`} alt={photoAlt} />
                  </div>
                )}

                <p
                  class={`text-xl leading-snug font-semibold text-ink font-display ${h.photo_ref ? 'mt-4' : ''}`}
                >
                  {h.headline}
                </p>

                {h.stat_block && (
                  <p class="mt-3 border-t border-dashed border-blue/40 pt-3 font-mono text-xs text-ink-soft">
                    {h.stat_block}
                  </p>
                )}

                {h.source_note && (
                  <p class="mt-2 font-mono text-[0.65rem] text-ink-soft/70 italic">
                    Source:{' '}
                    {h.source_post_url ? (
                      <a href={h.source_post_url} class="not-italic hover:underline">
                        {h.source_note}
                      </a>
                    ) : (
                      h.source_note
                    )}
                  </p>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>
  </main>
</Base>
