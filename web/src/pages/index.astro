---
import Base from '../layouts/Base.astro';
import { getPublishedHeadlines } from '../lib/db';

export const prerender = false;

const headlines = await getPublishedHeadlines();
---

<Base title="bluejays.space">
  <main class="mx-auto max-w-xl px-6 py-16">
    <h1 class="text-center text-3xl font-bold tracking-tight">bluejays.space</h1>
    <p class="mt-2 text-center text-neutral-600">The Scrapbook</p>

    {
      headlines.length === 0 && (
        <p class="mt-16 text-center text-neutral-500">
          No headlines published yet. Check back soon.
        </p>
      )
    }

    <ul class="mt-10 space-y-6">
      {
        headlines.map((h) => (
          <li class="overflow-hidden rounded-lg border border-neutral-200 bg-white shadow-sm">
            {h.photo_ref && (
              <img src={`/api/images/${h.photo_ref}`} alt="" class="h-48 w-full object-cover" />
            )}
            <div class="p-5">
              <p class="text-lg font-semibold leading-snug">{h.headline}</p>
              {h.stat_block && <p class="mt-2 text-sm text-neutral-600">{h.stat_block}</p>}
              {h.source_note && (
                <p class="mt-3 text-xs text-neutral-400">
                  Inspired by:{' '}
                  {h.source_post_url ? (
                    <a href={h.source_post_url} class="underline">
                      {h.source_note}
                    </a>
                  ) : (
                    h.source_note
                  )}
                </p>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </main>
</Base>
