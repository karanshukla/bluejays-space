---
import Base from '../layouts/Base.astro';
import { getPublishedHeadlines } from '../lib/db';

export const prerender = false;

const headlines = await getPublishedHeadlines();
---

<Base title="bluejays.space">
  <main class="mx-auto max-w-6xl px-6 py-12 sm:px-10">
    <div class="mb-6 flex justify-end">
      <a href="/admin" class="font-mono text-xs text-ink-soft uppercase hover:underline">Admin</a>
    </div>
    <h1 class="text-center text-5xl font-semibold tracking-tight text-ink font-display sm:text-6xl">
      bluejays.space
    </h1>
    <p class="mt-3 text-center font-mono text-sm tracking-wide text-ink-soft uppercase">
      The Scrapbook
    </p>

    {
      headlines.length === 0 && (
        <p class="mt-16 text-center font-mono text-sm text-ink-soft">
          No headlines published yet. Check back soon.
        </p>
      )
    }

    <ul class="scrapbook-grid mt-14">
      {
        headlines.map((h) => {
          // Real alt text for the public feed: a player name when player_ids is
          // populated, otherwise decorative (empty) per docs/ui-plan.md.
          const photoAlt = h.player_ids?.[0] ? `${h.player_ids[0]}` : '';
          const stampColor = h.register === 2 ? 'text-stamp-2' : 'text-stamp-1';
          return (
            <li>
              <div class="clipping relative border border-paper-edge bg-card p-5 pt-7 shadow-[3px_4px_0_rgba(42,33,24,0.12),0_10px_24px_-8px_rgba(42,33,24,0.25)]">
                <span class={`stamp ${stampColor}`}>Register {h.register}</span>

                {h.photo_ref && (
                  <div class="photo-mount mt-4 border border-paper-edge">
                    <img src={`/api/images/${h.photo_ref}`} alt={photoAlt} />
                  </div>
                )}

                <p class="mt-4 text-xl leading-snug font-semibold text-ink font-display">
                  {h.headline}
                </p>

                {h.stat_block && (
                  <p class="mt-3 border-t border-dashed border-paper-edge pt-3 font-mono text-xs text-ink-soft">
                    {h.stat_block}
                  </p>
                )}

                {h.source_note && (
                  <p class="mt-2 font-mono text-xs text-ink-soft italic">
                    Inspired by:{' '}
                    {h.source_post_url ? (
                      <a href={h.source_post_url} class="not-italic underline">
                        {h.source_note}
                      </a>
                    ) : (
                      h.source_note
                    )}
                  </p>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>
  </main>
</Base>
