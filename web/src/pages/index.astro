---
import Base from '../layouts/Base.astro';
import HeadlineCard from '../components/HeadlineCard.astro';
import { getPublishedHeadlines } from '../lib/db';

export const prerender = false;

const headlines = await getPublishedHeadlines();
---

<Base title="bluejays.space">
  <main class="mx-auto max-w-[1600px] px-6 py-12 sm:px-10">
    <h1 class="text-center text-5xl font-semibold tracking-tight text-ink font-display sm:text-6xl">
      bluejays.space
    </h1>

    {
      headlines.length === 0 && (
        <p class="mt-16 text-center font-mono text-sm text-ink-soft">
          No headlines published yet. Check back soon.
        </p>
      )
    }

    <ul class="scrapbook-grid mt-14">
      {headlines.map((h) => <HeadlineCard headline={h} />)}
    </ul>
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-link').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const path = btn.dataset.url;
        if (!path) return;
        try {
          await navigator.clipboard.writeText(`${location.origin}${path}`);
          const original = btn.textContent;
          btn.textContent = '✓';
          btn.classList.add('text-blue');
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('text-blue');
          }, 1500);
        } catch {
          // clipboard API unavailable — fall back to navigating to the permalink
          window.open(path, '_blank');
        }
      });
    });
  </script>
</Base>
