# bluejays-space — environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored. Only variables consumed by docker-compose are needed
# for local dev; per-service Railway variables are set in the Railway dashboard.

# --- Postgres (local dev) ---
POSTGRES_USER=bluejays
POSTGRES_PASSWORD=bluejays
POSTGRES_DB=bluejays

# --- Site URL (web) ---
# Canonical production origin, used to build absolute URLs for Open Graph
# meta tags, the RSS feed, and the sitemap. Production sets this to
# https://bluejays.space in the Railway dashboard; locally localhost is fine.
SITE_URL=http://localhost:4321

# --- handles service ---
BASE_DOMAIN=bluejays.space
HANDLES_FILE=handles.json
# Fine-grained PAT used by the request form to open handle PRs. Leave blank
# locally to disable submissions.
GITHUB_TOKEN=
GITHUB_REPO=karanshukla/bluejays-space

# --- ingest (generation job) ---
ANTHROPIC_API_KEY=
GENERATION_MODEL=claude-haiku-4-5
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Bluesky login needs an identifier (handle or email) alongside the app password.
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# Mastodon hashtag search needs no credentials (public API). Optionally point
# at a different instance than the default (mastodon.social) — a hashtag
# timeline only reflects what the queried instance has federated/seen, so a
# smaller/more Jays-relevant instance could be worth trying.
MASTODON_INSTANCE=
# mlb-api-mcp server URL (optional). When set, the generator gets live MLB
# stat/roster lookup via Claude's MCP connector — needed for the register-2
# real-fact-anchored subtype. Leave blank to run without MLB lookup.
MLB_MCP_URL=
# Shared-secret bearer token for the above, if the deployment sits behind a
# Cloudflare rule checking it (only needed if MLB_MCP_URL requires auth).
# The connector call originates from Anthropic's own infrastructure, not from
# inside Railway, so this can only be a plain static token — NOT Cloudflare
# Access (interactive login or two-header Service Tokens aren't supported by
# the connector's single-bearer-token auth model).
MLB_MCP_AUTH_TOKEN=

# --- Object storage (self-hosted S3-compatible — MinIO locally) ---
# ingest writes (uploads photos), web reads (proxies them at /api/images/*).
# Locally these point at the minio service below; in production point
# S3_ENDPOINT at wherever the MinIO service is deployed and use dedicated
# (non-root) credentials.
MINIO_ROOT_USER=bluejays
MINIO_ROOT_PASSWORD=bluejays-dev-only
S3_BUCKET=bluejays-images

# --- Admin auth (Cloudflare Access) ---
# The web app verifies Cloudflare Access JWTs itself so /admin and
# /api/headlines/* stay protected even when reached via Railway's direct
# *.up.railway.app domain (which bypasses Cloudflare's proxy). Set both in
# production (Railway). Locally the middleware skips verification when
# NODE_ENV is not 'production', so these can stay blank for dev.
#   CF_ACCESS_TEAM  — Zero Trust team name (the <team> in <team>.cloudflareaccess.com)
#   CF_ACCESS_AUD   — the Application Audience (AUD) tag from Zero Trust → Applications → (app) → Settings
CF_ACCESS_TEAM=
CF_ACCESS_AUD=
