# bluejays-space — environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored. Only variables consumed by docker-compose are needed
# for local dev; per-service Railway variables are set in the Railway dashboard.

# --- Postgres (local dev) ---
POSTGRES_USER=bluejays
POSTGRES_PASSWORD=bluejays
POSTGRES_DB=bluejays

# --- handles service ---
BASE_DOMAIN=bluejays.space
HANDLES_FILE=handles.json
# Fine-grained PAT used by the request form to open handle PRs. Leave blank
# locally to disable submissions.
GITHUB_TOKEN=
GITHUB_REPO=karanshukla/bluejays-space

# --- ingest (generation job) ---
ANTHROPIC_API_KEY=
GENERATION_MODEL=claude-haiku-4-5
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
BLUESKY_APP_PASSWORD=

# --- Object storage (self-hosted S3-compatible — MinIO locally) ---
# ingest writes (uploads photos), web reads (proxies them at /api/images/*).
# Locally these point at the minio service below; in production point
# S3_ENDPOINT at wherever the MinIO service is deployed and use dedicated
# (non-root) credentials.
MINIO_ROOT_USER=bluejays
MINIO_ROOT_PASSWORD=bluejays-dev-only
S3_BUCKET=bluejays-images
